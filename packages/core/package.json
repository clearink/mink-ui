{
  "name": "@mink-ui/core",
  "type": "module",
  "version": "0.0.14",
  "description": "mink-ui react components",
  "author": "clearink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clearink/mink-ui.git",
    "directory": "packages/core"
  },
  "keywords": [
    "mink-ui",
    "react",
    "components"
  ],
  "sideEffects": [
    "dist/*"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "esm",
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "./lib/index.js",
    "module": "./esm/index.mjs",
    "types": "./esm/index.d.ts"
  },
  "scripts": {
    "prepublishOnly": "tsc -b & mink build:core",
    "sub": "mink sub:core",
    "build": "mink build:core",
    "lint": "eslint src",
    "lint:ts": "tsc -b"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@babel/runtime": "catalog:",
    "@mink-ui/icons": "workspace:*",
    "@mink-ui/shared": "workspace:*",
    "classnames": "catalog:",
    "react-fast-compare": "catalog:",
    "react-is": "catalog:"
  },
  "devDependencies": {
    "@internal/cli": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-is": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
