{
  "name": "mink-ui",
  "type": "module",
  "version": "0.0.1",
  "private": "true",
  "description": "mink ui",
  "author": "clearink",
  "license": "MIT",
  "keywords": [
    "ui"
  ],
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "commit": "git-cz",
    "prepare": "husky",
    "postinstall": "pnpm build:cli",
    "dev": "pnpm --filter @apps/website dev",
    "gen:icons": "pnpm --filter @mink-ui/icons gen",
    "sub:core": "pnpm --filter @mink-ui/core sub",
    "sub:icons": "pnpm --filter @mink-ui/icons sub",
    "sub:shared": "pnpm --filter @mink-ui/shared sub",
    "build:cli": "pnpm --filter @internal/cli build:all",
    "build:website": "pnpm --filter @apps/website build",
    "ci:version": "pnpm changeset version",
    "lint": "eslint --fix",
    "test": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@changesets/cli": "2.29.8",
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@commitlint/cz-commitlint": "20.4.1",
    "@eslint-react/eslint-plugin": "3.0.0",
    "@types/node": "22.16.0",
    "commitizen": "4.3.1",
    "cross-env": "10.1.0",
    "eslint": "10.2.1",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "tslib": "2.5.0",
    "typescript": "5.4.5",
    "vitest": "4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,css,sass,scss,md,json,yml,yaml}": [
      "eslint --cache-location ./node_modules/.cache/.eslintcache --cache --fix",
      "git add"
    ]
  }
}
