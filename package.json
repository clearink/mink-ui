{
  "name": "mink-ui",
  "type": "module",
  "version": "0.0.1",
  "private": "true",
  "description": "mink ui",
  "author": "clearink",
  "license": "MIT",
  "keywords": [
    "ui"
  ],
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "commit": "git-cz",
    "prepare": "husky",
    "postinstall": "pnpm build:cli",
    "setup": "pnpm install && pnpm gen:icons && pnpm sub:all",

    "dev": "pnpm -F @apps/website dev",

    "sub:all": "pnpm sub:icons && pnpm sub:shared",
    "lint:all": "pnpm core:lint && pnpm lint:icons && pnpm lint:shared",

    "sub:core": "pnpm -F @mink-ui/core sub",
    "lint:core": "pnpm -F @mink-ui/core lint",
    "build:core": "pnpm -F @mink-ui/core build",

    "gen:icons": "pnpm -F @mink-ui/icons gen",
    "sub:icons": "pnpm -F @mink-ui/icons sub",
    "build:icons": "pnpm -F @mink-ui/icons build",
    "lint:icons": "pnpm -F @mink-ui/icons lint",

    "sub:shared": "pnpm -F @mink-ui/shared sub",
    "build:shared": "pnpm -F @mink-ui/shared build",
    "lint:shared": "pnpm -F @mink-ui/shared lint",

    "build:cli": "pnpm -F @internal/cli build:all",

    "lint:website": "pnpm -F @apps/website lint",
    "build:website": "pnpm -F @apps/website build",

    "ci:version": "pnpm changeset version",

    "test": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@changesets/cli": "2.29.8",
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@commitlint/cz-commitlint": "20.4.1",
    "@eslint-react/eslint-plugin": "3.0.0",
    "@types/node": "22.16.0",
    "commitizen": "4.3.1",
    "cross-env": "10.1.0",
    "eslint": "10.2.1",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "tslib": "2.5.0",
    "typescript": "5.4.5",
    "vitest": "4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,css,sass,scss,md,json,yml,yaml}": [
      "eslint --cache-location ./node_modules/.cache/.eslintcache --cache --fix",
      "git add"
    ]
  }
}
